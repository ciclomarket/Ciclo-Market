# ============================================
# CICLO MARKET - VARIABLES DE ENTORNO (EJEMPLO)
# ============================================
# 
# INSTRUCCIONES:
# 1. Copiar este archivo a .env: cp .env.example .env
# 2. Completar con valores de desarrollo (NUNCA valores de producción)
# 3. NUNCA commitear el archivo .env
#
# PRODUCCIÓN:
# Estas variables deben configurarse en:
# - Render Dashboard (para backend)
# - Firebase Functions Secrets (para functions)
# - Vercel/Netlify env vars (para frontend si aplica)

# --------------------------------------------
# FRONTEND (Vite) - Variables públicas
# Estas pueden exponerse al cliente
# --------------------------------------------

# Supabase (público - anon key)
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_PUBLIC_KEY

# Buckets de Storage
VITE_SUPABASE_STORAGE_BUCKET=listings
VITE_SUPABASE_AVATAR_BUCKET=avatars

# API Backend
VITE_API_BASE_URL=https://your-api.render.com
VITE_API_FALLBACK_URL=
VITE_MARKET_USE_API=true

# URLs de share para OG (Open Graph)
VITE_SHARE_BASE_URL=https://www.your-domain.ar
VITE_FACEBOOK_APP_ID=YOUR_FB_APP_ID

# Image optimization
VITE_USE_IMAGE_PROXY=false
VITE_SUPABASE_IMG_TRANSFORM=true
VITE_IMAGE_DEFAULT_WIDTH=480
VITE_IMAGE_DEFAULT_QUALITY=70
VITE_IMAGE_ENABLE_WEBP=true
VITE_IMAGE_ENABLE_AVIF=false
VITE_IMG_BASE=${VITE_SUPABASE_URL}/storage/v1/render/image

# Analytics (público)
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX
VITE_META_PIXEL_ID=XXXXXXXXXX
VITE_POSTHOG_KEY=phc_XXXXXXXXXXXXXXXXXXXXXX
VITE_POSTHOG_HOST=https://us.i.posthog.com

# Google Maps
VITE_GOOGLE_MAPS_KEY=YOUR_GOOGLE_MAPS_KEY
VITE_GOOGLE_MAPS_MAP_ID=YOUR_MAP_ID

# --------------------------------------------
# BACKEND (Node/Express) - Variables PRIVADAS
# NUNCA exponer estas al frontend
# --------------------------------------------

NODE_ENV=development

# Supabase (server-side - SERVICE ROLE KEY = acceso total)
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# URLs del servidor
SERVER_BASE_URL=https://your-api.render.com
FRONTEND_URL=https://www.your-domain.ar,https://your-domain.ar
PUBLIC_BASE_URL=https://your-api.render.com

# Seguridad
CRON_SECRET=YOUR_RANDOM_SECRET_MIN_32_CHARS
UPSELL_WHATSAPP_LINK_SECRET=YOUR_RANDOM_SECRET_32_CHARS
NEWSLETTER_UNSUB_SECRET=YOUR_RANDOM_SECRET_32_CHARS

# MercadoPago (server-side)
MERCADOPAGO_ACCESS_TOKEN=APP_USR-XXXXXXXXXXXXXXXX

# Email - Opción A: Resend (recomendado)
RESEND_API_KEY=re_XXXXXXXXXXXXXXXXXXXX
RESEND_AUDIENCE_GENERAL_ID=XXXXXXXX-XXXX-XXXX-XXXX-XXXXXXXXXXXX
VERIFICATION_ALERT_EMAIL=admin@your-domain.ar

# Email - Opción B: SMTP (alternativo)
SMTP_ENABLED=false
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=YOUR_SMTP_USER
SMTP_PASSWORD=YOUR_SMTP_PASSWORD
SMTP_FROM="Ciclo Market <notifications@your-domain.ar>"
BREVO_API_KEY=xkeysib-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Marketing Automations
MARKETING_AUTOMATIONS_ENABLED=true
MARKETING_AUTOMATIONS_CRON=30 10 * * 1
MARKETING_AUTOMATIONS_TZ=America/Argentina/Buenos_Aires

# Otros
CRON_SECRET=4f2c2b4aad984c448c583182d4c8762b
AVAILABLE_PLANS=[{"code":"basic","name":"Básico","price":9000},{"code":"premium","name":"Premium","price":13000}]
MERCHANT_ORDER_URL=https://api.mercadopago.com/merchant_orders
